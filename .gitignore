build/
dist/
*.spec.bak
build_log.txt

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Selenium driver cache ─────────────────────────────────────────────────────
.wdm/

# ── pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

